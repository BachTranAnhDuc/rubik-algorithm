{
  "name": "@rubik/visualizer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ssr": {
      "types": "./dist/ssr.d.ts",
      "import": "./dist/ssr.js",
      "default": "./dist/ssr.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rubik/cube-core": "workspace:*"
  },
  "peerDependencies": {
    "@react-three/drei": "^9.0.0",
    "@react-three/fiber": "^9.0.0",
    "react": "^19.0.0",
    "three": "^0.170.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    },
    "@react-three/drei": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^2.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.2.5",
    "vitest": "^2.1.0"
  }
}
