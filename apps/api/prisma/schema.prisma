// Sub-phase 1 placeholder. Models land in sub-phase 2 (plan 05).
// This empty schema exists only so `prisma generate` produces a Prisma
// client and `PrismaService` can instantiate at boot.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
