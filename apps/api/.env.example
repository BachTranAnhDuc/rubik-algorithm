# Runtime
NODE_ENV=development
PORT=3001

# Postgres — pooled connection for app traffic, direct URL for migrations.
# DATABASE_URL=postgres://rubik:rubik@localhost:5432/rubik
# DIRECT_URL=postgres://rubik:rubik@localhost:5432/rubik

# Redis — used by cache-manager and the throttler.
# REDIS_URL=redis://localhost:6379

# JWT — symmetric secrets for the app's own token pair.
# Both must be ≥32 characters. Rotate for prod; never reuse across environments.
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=

# Google OAuth (optional in sub-phase 1; required when the auth module lands).
# GOOGLE_CLIENT_ID=

# Telemetry (optional). With these unset the api boots without OTel/Sentry.
# OTEL_EXPORTER_OTLP_ENDPOINT=
# SENTRY_DSN=

# CORS (comma-separated origins). Optional in dev; required in prod.
# CORS_ORIGINS=http://localhost:3000
