{
  "name": "@rubik/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --watch --import @swc-node/register/esm-register src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "seed": "tsx prisma/seed.ts",
    "content:validate": "tsx prisma/seed.ts --validate-only"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/client": "^6.0.0",
    "@rubik/cube-core": "workspace:*",
    "@rubik/shared": "workspace:*",
    "@sentry/node": "^8.0.0",
    "cache-manager": "^6.0.0",
    "cache-manager-redis-yet": "^5.0.0",
    "compression": "^1.7.5",
    "dayjs": "^1.11.13",
    "google-auth-library": "^9.15.0",
    "helmet": "^8.0.0",
    "js-yaml": "^4.1.1",
    "nestjs-pino": "^4.1.0",
    "nestjs-prisma": "^0.24.0",
    "nestjs-zod": "^4.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc-node/register": "^1.10.10",
    "@swc/core": "^1.10.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.0",
    "supertest": "^7.0.0",
    "testcontainers": "^10.18.0",
    "tsx": "^4.21.0",
    "unplugin-swc": "^1.5.0",
    "vitest": "^2.1.0"
  }
}
