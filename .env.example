# Database (Compose-friendly defaults)
DATABASE_URL=postgresql://rubik:rubik@localhost:5432/rubik
DIRECT_URL=postgresql://rubik:rubik@localhost:5432/rubik

# Redis
REDIS_URL=redis://localhost:6379

# Auth — Google OAuth (api side)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT secrets — generate with `openssl rand -base64 32`
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me

# API server
API_PORT=3001
API_BASE_URL=http://localhost:3001

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me

# Telemetry — optional in dev
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Analytics — optional, decided in design open questions
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
